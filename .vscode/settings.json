{
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "go.addTags": {
    "tags": "json,url,header",
    "promptForTags": true
  },
  "go.coverageDecorator": {
    "type": "highlight",
    "coveredHighlightColor": "rgba(64,128,128,0.5)",
    "uncoveredHighlightColor": "rgba(128,64,64,0.25)",
    "coveredGutterStyle": "blockgreen",
    "uncoveredGutterStyle": "blockred"
  },
  "go.coverOnSingleTest": true,
  "go.coverOnSave": true,
  "go.formatFlags": ["-s", "-w"],
  "go.lintOnSave": "package",
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [],
  "cSpell.customDictionaries": {
    "custom-dictionary-workspace": {
      "name": "custom-dictionary-workspace",
      "path": "${workspaceFolder:servicenow-sdk-go}/.cspell/custom-dictionary-workspace.txt",
      "addWords": true,
      "scope": "workspace"
    }
  },
  "cSpell.words": [
    "dateonly",
    "Deserializers",
    "onlychanged",
    "onlychangedtonil",
    "timeonly"
  ],
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/table-api/display_value.go": true,
    "**/table-api/display_value_test.go": true,
    "**/table-api/entry.go": true,
    "**/table-api/fragment.go": true,
    "**/table-api/logical_operator.go": true,
    "**/table-api/order_by.go": true,
    "**/table-api/order_direction.go": true,
    "**/table-api/page_iterator.go": true,
    "**/table-api/page_iterator_test.go": true,
    "**/table-api/page_result.go": true,
    "**/table-api/query.go": true,
    "**/table-api/relational_operator.go": true,
    "**/table-api/table_collection_response.go": true,
    "**/table-api/table_collection_response2.go": true,
    "**/table-api/table_collection_response2_test.go": true,
    "**/table-api/table_entry.go": true,
    "**/table-api/table_entry_test.go": true,
    "**/table-api/table_get_request_configuration.go": true,
    "**/table-api/table_get_request_configuration_test.go": true,
    "**/table-api/table_get_request_configuration2.go": true,
    "**/table-api/**request_configuration**.go": true,
    "**/table-api/table_item_request_builder_**_query_parameters**.go": true,
    "**/table-api/table_item_request_builder.go": true,
    "**/table-api/table_item_request_builder_test.go": true,
    "**/table-api/table_item_response.go": true,
    "**/table-api/table_item_response2.go": true,
    "**/table-api/table_item_response2_test.go": true,
    "**/table-api/table_page_iterator.go": true,
    "**/table-api/table_page_iterator_test.go": true,
    "**/table-api/table_request_builder_**_query_parameters**.go": true,
    "**/table-api/table_request_builder_post_query_paramters.go": true,
    "**/table-api/table_request_builder_post_query_paramters_test.go": true,
    "**/table-api/table_request_builder.go": true,
    "**/table-api/table_request_builder_test.go": true,
    "**/table-api/table_response.go": true,
    "**/table-api/table_value.go": true,
    "**/table-api/table_value_test.go": true,
    "**/table-api/view.go": true,
    "**/table-api/view_test.go": true
  }
}
