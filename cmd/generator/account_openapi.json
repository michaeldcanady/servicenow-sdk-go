{
  "$schema": "https://spec.openapis.org/oas/3.0/schema/2024-10-18",
  "openapi": "3.0.0",
  "info": {
    "title": "ServiceNow Account API",
    "description": "The Account API provides endpoints to retrieve Customer Service Management (CSM) account records.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/now/account": {
      "x-go-name": "Account",
      "get": {
        "summary": "Retrieves a specified set of Customer Service Management (CSM) accounts.",
        "x-go-is-collection": true,
        "x-go-result-type": "Account",
        "parameters": [
          {
            "name": "sysparm_limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Maximum number of records to return."
          },
          {
            "name": "sysparm_offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting record index for which to begin retrieving records."
          },
          {
            "name": "sysparm_query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Encoded query used to filter the result set."
          }
        ]
      }
    },
    "/api/now/account/{sys_id}": {
      "x-go-name": "AccountItem",
      "get": {
        "summary": "Retrieves the specified Customer Service Management (CSM) account.",
        "x-go-is-item": true,
        "x-go-result-type": "Account"
      }
    }
  },
  "components": {
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "account_code": { "type": "string" },
          "account_parent": { "type": "string" },
          "account_path": { "type": "string" },
          "active_escalation": { "type": "string" },
          "apple_icon": { "type": "string" },
          "banner_image": { "type": "string" },
          "banner_image_light": { "type": "string" },
          "banner_text": { "type": "string" },
          "city": { "type": "string" },
          "contact": { "type": "string" },
          "country": { "type": "string" },
          "customer": { "type": "boolean" },
          "discount": { "type": "number" },
          "fax_phone": { "type": "string" },
          "fiscal_year": { "type": "string" },
          "lat_long_error": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "manufacturer": { "type": "boolean" },
          "market_cap": { "type": "number" },
          "name": { "type": "string" },
          "notes": { "type": "string" },
          "num_employees": { "type": "integer" },
          "number": { "type": "string" },
          "parent": { "type": "string" },
          "partner": { "type": "boolean" },
          "phone": { "type": "string" },
          "primary": { "type": "boolean" },
          "primary_contact": { "type": "string" },
          "profits": { "type": "number" },
          "publicly_traded": { "type": "boolean" },
          "rank_tier": { "type": "string" },
          "registration_code": { "type": "string" },
          "revenue_per_year": { "type": "number" },
          "state": { "type": "string" },
          "stock_price": { "type": "string" },
          "stock_symbol": { "type": "string" },
          "street": { "type": "string" },
          "sys_class_name": { "type": "string" },
          "sys_created_by": { "type": "string" },
          "sys_created_on": { "type": "string", "format": "date-time" },
          "sys_id": { "type": "string" },
          "sys_mod_count": { "type": "integer" },
          "sys_updated_by": { "type": "string" },
          "sys_updated_on": { "type": "string", "format": "date-time" },
          "theme": { "type": "string" },
          "vendor": { "type": "boolean" },
          "vendor_manager": { "type": "string" },
          "vendor_type": { "type": "string" },
          "website": { "type": "string" },
          "zip": { "type": "string" }
        }
      }
    }
  }
}
