{
  "name": "ServiceNow SDK Go",
  "dockerComposeFile": "podman-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/servicenow-sdk-go",
  "customizations": {
    "vscode": {
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.gopath": "/go",
        "go.testTimeout": "30s",
        "go.lintOnSave": "package",
        "go.lintTool": "golangci-lint",
        "go.formatTool": "gofmt",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "always"
        }
      },
      "extensions": [
        "golang.go"
      ]
    }
  },
  "remoteUser": "vscode",
  "updateContentCommand": "go mod download",
  "postCreateCommand": "just --version",
  "features": {
    "./xdg-utils": {},
    "./gemini-persistence": {},
    "./go-cache": {},
    "./antigravity": {},
    "./ollama-cli": {},
    "ghcr.io/stu-bell/devcontainer-features/gemini-cli:0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "version": "latest"
    },
    "ghcr.io/guiyomh/features/just:0": {}
  },
  "containerUser": "vscode"
}