{
  "name": "ServiceNow SDK Go",
  "dockerComposeFile": "podman-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/servicenow-sdk-go",
  "customizations": {
    "vscode": {
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.gopath": "/go",
        "go.testTimeout": "30s",
        "go.lintOnSave": "package",
        "go.lintTool": "golangci-lint",
        "go.formatTool": "gofmt",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "always"
        }
      },
      "extensions": [
        "golang.go",
        "EditorConfig.EditorConfig",
        "GitHub.vscode-pull-request-github",
        "streetsidesoftware.code-spell-checker",
        "usernamehw.errorlens",
        "msyrus.go-doc",
        "766b.go-outliner",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "remoteUser": "vscode",
  "updateContentCommand": "go mod download",
  "postCreateCommand": "just --version",
  "features": {
    "./gemini-persistence": {},
    "./go-cache": {},
    "./podman-remote": {
      "hostSocketPath": "/var/run/user/1000/podman/podman.sock"
    },
    "./xdg-utils": {
      "hostBrowserPipePath": "/home/michael/hostbrowserpipe"
    },
    "./antigravity": {},
    "./ollama-cli": {},
    "./ollama-server": {},
    "ghcr.io/stu-bell/devcontainer-features/gemini-cli:0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "version": "latest"
    },
    "ghcr.io/guiyomh/features/just:0": {}
  },
  "containerUser": "vscode"
}
