{
    "id": "xdg-utils",
    "version": "1.0.0",
    "name": "XDG Utils",
    "description": "Installs xdg-utils and configures a mount for the host browser pipe.",
    "options": {
        "hostBrowserPipePath": {
            "type": "string",
            "propose": "/home/michael/hostbrowserpipe",
            "description": "Path to the host browser pipe"
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ],
    "mounts": [
        {
            "source": "${options:hostBrowserPipePath}",
            "target": "/tmp/hostbrowserpipe",
            "type": "bind"
        }
    ]
}