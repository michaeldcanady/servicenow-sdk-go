    // {{camel .Name}}URLTemplate is the URL template for this endpoint.
    {{camel .Name}}URLTemplate = "{+baseurl}{{.FullPath}}{{if .AllQueryParameters}}{?{{range $i, $p := .AllQueryParameters}}{{if $i}},{{end}}{{$p.Name}}{{end}}}{{end}}"
)

// {{.Name}}RequestBuilder provides operations for managing the {{.Name}} endpoint.
