{{range .Methods}}
// {{.Name}} sends a {{.HTTPVerb}} request to the endpoint.
func (rB *{{$.Name}}RequestBuilder{{if $.GenericType}}[{{$.GenericType}}]{{end}}) {{.Name}}(
    ctx context.Context,
    {{if .RequestType}}body {{.RequestType}},{{end}}
    requestConfiguration *{{$.Name}}RequestBuilder{{.Name}}RequestConfiguration,
) (
    {{if .ResponseType}}{{.ResponseType}},{{end}}
    error,
) {
    if internal.IsNil(rB) {
        {{if .ResponseType}}return nil, nil{{else}}return nil{{end}}
    }

    if internal.IsNil(requestConfiguration) {
        requestConfiguration = &{{$.Name}}RequestBuilder{{.Name}}RequestConfiguration{}
    }

    {{/* ------------------------------------------------------------ */}}
    {{/* REQUIRED QUERY PARAMETER VALIDATION                          */}}
    {{/* ------------------------------------------------------------ */}}
    {{- $responseType := .ResponseType -}}
    {{- $required := false -}}
    {{- range .QueryParameters -}}
        {{- if .Required -}}
            {{- $required = true -}}
        {{- end -}}
    {{- end -}}

    {{- if $required }}
        // Validate required query parameters
        queryParameters := requestConfiguration.QueryParameters
        {{- range .QueryParameters }}
            {{- if .Required }}
        if queryParameters.{{pascal .Name}} == nil || *queryParameters.{{pascal .Name}} == "" {
            return {{if $responseType}}nil, {{end}}errors.New("{{pascal .Name}} is required")
        }
            {{- end }}
        {{- end }}
    {{- end }}

    {{if or .IsCollection .IsAttachmentFile}}
    headerOpt := nethttplibrary.NewHeadersInspectionOptions()
    headerOpt.InspectResponseHeaders = true
    requestConfiguration.Options = append(requestConfiguration.Options, headerOpt)
    {{end}}

    requestInfo, err := rB.To{{.Name}}RequestInformation(ctx, {{if .RequestType}}body,{{end}} requestConfiguration)
    if err != nil {
        {{if .ResponseType}}return nil, err{{else}}return err{{end}}
    }

    errorMapping := abstractions.ErrorMappings{
        "XXX": newInternal.CreateServiceNowErrorFromDiscriminatorValue,
    }

    {{if eq .HTTPVerb "DELETE"}}
    return rB.GetRequestAdapter().SendNoContent(ctx, requestInfo, errorMapping)
    {{else}}
    {{if .IsAttachmentFile}}
    resp, err := rB.GetRequestAdapter().SendPrimitive(ctx, requestInfo, "[]byte", errorMapping)
    if err != nil {
        return nil, err
    }
    if resp == nil {
        return nil, nil
    }
    typedResp, ok := resp.([]byte)
    if !ok {
        return nil, errors.New("resp is not []byte")
    }

    var file serialization.Parsable = NewFileWithContent()

    metadataHeaders := headerOpt.GetResponseHeaders().Get("x-attachment-metadata")
    if len(metadataHeaders) > 0 {
        metadata := metadataHeaders[0]

        var node serialization.ParseNode

        node, err = jsonserialization.NewJsonParseNode([]byte(metadata))
        if err != nil {
            return nil, err
        }

        file, err = node.GetObjectValue(CreateFileWithContentFromDiscriminatorValue)
        if err != nil {
            return nil, err
        }
    }

    typedFile, ok := file.(*FileWithContentModel)
    if !ok {
        return nil, errors.New("file is not *FileWithContentModel")
    }

    if err := typedFile.SetContent(typedResp); err != nil {
        return nil, err
    }

    return typedFile, nil
    {{else}}
    {{if .IsPrimitive}}
    res, err := rB.GetRequestAdapter().SendPrimitive(ctx, requestInfo, "{{.PrimitiveType}}", errorMapping)
    {{else}}
    res, err := rB.GetRequestAdapter().Send(
        ctx,
        requestInfo,
        {{if .ResponseFactory}}{{.ResponseFactory}}{{else if $.GenericType}}newInternal.{{if .IsCollection}}ServiceNowCollectionResponse{{else}}ServiceNowItemResponse{{end}}FromDiscriminatorValue[{{$.GenericType}}](rB.factory){{else}}nil{{end}},
        errorMapping,
    )
    {{end}}
    if err != nil {
        return {{if .ResponseType}}nil, {{end}}err
    }

    if internal.IsNil(res) {
        return nil, nil
    }

    {{if $.GenericType}}
    typedRes, ok := res.({{.ResponseType}})
    if !ok {
        return nil, fmt.Errorf("resp is not %T", (*{{.ResponseType}})(nil))
    }
    {{else}}
    typedRes, ok := res.({{.ResponseType}})
    if !ok {
        return nil, errors.New("unexpected response type")
    }
    {{end}}

    {{if .IsCollection}}
    newInternal.ParseHeaders(typedRes, headerOpt.GetResponseHeaders())
    {{end}}
    return typedRes, nil
    {{end}}
    {{end}}
}

// To{{.Name}}RequestInformation creates the RequestInformation for a {{.HTTPVerb}} request.
func (rB *{{$.Name}}RequestBuilder{{if $.GenericType}}[{{$.GenericType}}]{{end}}) To{{.Name}}RequestInformation(
    ctx context.Context,
    {{if .RequestType}}body {{.RequestType}},{{end}}
    requestConfiguration *{{$.Name}}RequestBuilder{{.Name}}RequestConfiguration,
) (*abstractions.RequestInformation, error) {

    if internal.IsNil(rB) || internal.IsNil(rB.RequestBuilder) {
        return nil, nil
    }

    requestInfo := abstractions.NewRequestInformationWithMethodAndUrlTemplateAndPathParameters(
        abstractions.{{.HTTPVerb}},
        rB.GetURLTemplate(),
        rB.GetPathParameters(),
    )

    kiotaRequestInfo := &newInternal.KiotaRequestInformation{RequestInformation: requestInfo}

    if !internal.IsNil(requestConfiguration) {
        if headers := requestConfiguration.Headers; !internal.IsNil(headers) {
            kiotaRequestInfo.Headers.AddAll(headers)
        }
        if options := requestConfiguration.Options; !internal.IsNil(options) {
            kiotaRequestInfo.AddRequestOptions(options)
        }
        if queryParams := requestConfiguration.QueryParameters; !internal.IsNil(queryParams) {
            kiotaRequestInfo.AddQueryParameters(queryParams)
        }
    }

    {{if or (eq .HTTPVerb "GET") (eq .HTTPVerb "HEAD")}}
    kiotaRequestInfo.Headers.TryAdd(
        internalHttp.RequestHeaderAccept.String(),
        newInternal.ContentTypeApplicationJSON,
    )
    {{end}}

    {{if .IsStream}}
    kiotaRequestInfo.SetStreamContentAndContentType(body.GetData(), body.GetContentType())
    {{else if .IsMultipart}}
    err := kiotaRequestInfo.SetContentFromParsable(ctx, rB.GetRequestAdapter(), newInternal.ContentTypeApplicationJSON, body)
    if err != nil {
        return nil, err
    }
    {{else if .RequestType}}
    kiotaRequestInfo.Headers.TryAdd(
        internalHttp.RequestHeaderAccept.String(),
        newInternal.ContentTypeApplicationJSON,
    )
    if !internal.IsNil(body) {
        if err := kiotaRequestInfo.SetContentFromParsable(ctx, rB.GetRequestAdapter(), newInternal.ContentTypeApplicationJSON, body); err != nil {
            return nil, err
        }
    }
    {{end}}

    return kiotaRequestInfo.RequestInformation, nil
}
{{end}}
