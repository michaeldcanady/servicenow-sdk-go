    newInternal.RequestBuilder
    {{if .GenericType}}factory serialization.ParsableFactory{{end}}
}

// New{{.Name}}RequestBuilderInternal instantiates a new {{.Name}}RequestBuilder with the provided path parameters and request adapter.
func New{{.Name}}RequestBuilderInternal{{if .GenericType}}[{{.GenericType}} {{.BaseType}}]{{end}}(
    pathParameters map[string]string,
    requestAdapter abstractions.RequestAdapter,
    {{if .GenericType}}factory serialization.ParsableFactory,{{end}}
) *{{.Name}}RequestBuilder{{if .GenericType}}[{{.GenericType}}]{{end}} {
    return &{{.Name}}RequestBuilder{{if .GenericType}}[{{.GenericType}}]{{end}}{
        newInternal.NewBaseRequestBuilder(requestAdapter, {{camel .Name}}URLTemplate, pathParameters),
        {{if .GenericType}}factory,{{end}}
    }
}

// New{{.Name}}RequestBuilder instantiates a new {{.Name}}RequestBuilder with a raw URL.
func New{{.Name}}RequestBuilder{{if .GenericType}}[{{.GenericType}} {{.BaseType}}]{{end}}(
    rawURL string,
    requestAdapter abstractions.RequestAdapter,
    {{if .GenericType}}factory serialization.ParsableFactory,{{end}}
) *{{.Name}}RequestBuilder{{if .GenericType}}[{{.GenericType}}]{{end}} {
    urlParams := map[string]string{newInternal.RawURLKey: rawURL}
    return New{{.Name}}RequestBuilderInternal{{if .GenericType}}[{{.GenericType}}]{{end}}(urlParams, requestAdapter {{if .GenericType}}, factory{{end}})
}

